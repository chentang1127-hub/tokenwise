# TokenWise Core — Environment overrides
# Copy this to .env and adjust before docker compose up -d.
#
# All TW_* vars override the corresponding keys in config.yaml.
# Leave a var unset to use the value from config.yaml.

# ── Caddy Domains ────────────────────────────────────────
# Set these to your real domains for automatic TLS.
# For local dev without a domain, leave as-is (Caddy runs on :80).
CADDY_DASHBOARD_DOMAIN=dashboard.yourdomain.com
CADDY_PROXY_DOMAIN=proxy.yourdomain.com

# ── TokenWise Runtime ────────────────────────────────────
# Set to true for Docker/headless servers (no browser popup).
TW_HEADLESS=true

# Override config.yaml values at runtime:
# TW_PROXY_LISTEN=0.0.0.0:9401
# TW_PROXY_ADMIN=0.0.0.0:9400
# TW_DB_PATH=/app/tokenwise.db
# TW_LICENSE_KEY=tw_pro_...
# TW_LOCALE=en

# ── Logging ──────────────────────────────────────────────
RUST_LOG=info,tokenwise=debug
